/* 圆桌讨论 · 话题总结 - 阅读态 UI */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 220rpx;
  overflow-x: hidden;
  width: 100%;
  max-width: 100vw;
}

/* Header */
.header {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 20;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.topic-block {
  padding: 24rpx 32rpx;
  background: rgba(249, 250, 251, 0.5);
  border-bottom: 1rpx solid #f0f0f0;
}

.topic-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #9ca3af;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.topic-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #111;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.step-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4ade80;
  border: 2rpx solid #fff;
}

.step-dot-done {
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
  box-shadow: none;
}

.step-text {
  color: #111;
}

.step-text-inactive {
  color: #9ca3af;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #e5e7eb;
  margin: 0 24rpx;
  margin-bottom: 36rpx;
}

/* Main */
.main {
  height: calc(100vh - 320rpx);
  padding: 32rpx;
  overflow-x: hidden;
  max-width: 100%;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
  padding: 48rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: summary-spin 0.8s linear infinite;
}

@keyframes summary-spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.section {
  margin-bottom: 48rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #9ca3af;
  letter-spacing: 0.05em;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

/* Hero */
.section-hero {
  text-align: center;
  margin-bottom: 48rpx;
}

.hero-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #111;
  color: #fff;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 24rpx;
}

.moderator-closing-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  text-align: left;
}

.moderator-closing-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #6b7280;
}

/* Leap card */
.leap-card {
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.leap-item {
  padding: 32rpx;
}

.leap-from {
  background: rgba(249, 250, 251, 0.6);
  border-bottom: 1rpx solid #f3f4f6;
}

.leap-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 8rpx;
}

.leap-to-title {
  color: #2563eb;
}

.leap-desc {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

.leap-to .leap-desc {
  color: #1f2937;
}

.leap-arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  margin: -24rpx auto -32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9ca3af;
  position: relative;
  z-index: 10;
}

/* Pillars */
.pillars {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.pillar-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: flex-start;
}

.pillar-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.pillar-body {
  flex: 1;
  min-width: 0;
}

.pillar-head {
  margin-bottom: 8rpx;
}

.pillar-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #111;
}

.pillar-divider {
  color: #d1d5db;
  margin: 0 12rpx;
}

.pillar-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #2563eb;
}

.pillar-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* Risks */
.risks-card {
  background: rgba(254, 242, 242, 0.6);
  border-radius: 24rpx;
  border: 1rpx solid #fecaca;
  padding: 32rpx;
}

.risk-item {
  position: relative;
  padding-left: 32rpx;
  margin-bottom: 32rpx;
}

.risk-item:last-child {
  margin-bottom: 0;
}

.risk-dot {
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f87171;
}

.risk-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #991b1b;
  margin-bottom: 8rpx;
}

.risk-desc {
  font-size: 24rpx;
  color: rgba(185, 28, 28, 0.85);
  line-height: 1.6;
}

/* Conclusion */
.conclusion-card {
  background: #111;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.conclusion-quote {
  position: absolute;
  right: -32rpx;
  top: -32rpx;
  font-size: 120rpx;
  color: rgba(255, 255, 255, 0.05);
  font-family: serif;
}

.conclusion-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #9ca3af;
  letter-spacing: 0.05em;
  margin-bottom: 16rpx;
}

.conclusion-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #f3f4f6;
}

/* Footer */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e5e7eb;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 30;
}

.actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.action-span-2 {
  flex: 2;
}

.action-span-1 {
  flex: 1;
}

.action-primary {
  background: #111;
  color: #fff;
  border: 1rpx solid #111;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.action-primary::after {
  border: none;
}

.action-secondary {
  background: #fff;
  color: #374151;
  border: 1rpx solid #e5e7eb;
}

.action-secondary::after {
  border: none;
}
