<view class="page">
  <view class="header">
    <view class="topic-block">
      <text class="topic-label">当前议题 / TOPIC</text>
      <text class="topic-title">{{topic}}</text>
    </view>
    <view class="steps">
      <view class="step">
        <view class="step-dot step-dot-done"><text>✓</text></view>
        <text class="step-text step-text-inactive">邀请嘉宾</text>
      </view>
      <view class="step-line"></view>
      <view class="step">
        <view class="step-dot step-dot-done"><text>✓</text></view>
        <text class="step-text step-text-inactive">圆桌讨论</text>
      </view>
      <view class="step-line"></view>
      <view class="step step-active">
        <view class="step-dot"><text>3</text><view class="step-badge"></view></view>
        <text class="step-text">话题总结</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="main">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">主持人正在总结中…</text>
    </view>
    <block wx:if="{{!loading}}">
      <view class="section-hero">
        <view class="hero-icon">⚡</view>
        <text class="hero-title">知识网络已生成</text>
        <view class="moderator-closing-card">
          <text class="moderator-closing-text">{{moderatorClosing}}</text>
        </view>
      </view>

      <view class="section" wx:if="{{knowledgeNetwork.leap && knowledgeNetwork.leap.length >= 2}}">
        <text class="section-label">01 / 核心定义的跃迁</text>
        <view class="leap-card">
          <view class="leap-item leap-from">
            <text class="leap-title">{{knowledgeNetwork.leap[0].title}}</text>
            <text class="leap-desc">{{knowledgeNetwork.leap[0].desc}}</text>
          </view>
          <view class="leap-arrow">↓</view>
          <view class="leap-item leap-to">
            <text class="leap-title leap-to-title">{{knowledgeNetwork.leap[1].title}}</text>
            <text class="leap-desc">{{knowledgeNetwork.leap[1].desc}}</text>
          </view>
        </view>
      </view>

      <view class="section" wx:if="{{knowledgeNetwork.pillars && knowledgeNetwork.pillars.length}}">
        <text class="section-label">02 / 实现路径的三大支柱</text>
        <view class="pillars">
          <view class="pillar-card" wx:for="{{knowledgeNetwork.pillars}}" wx:key="label">
            <view class="pillar-num">{{index + 1}}</view>
            <view class="pillar-body">
              <view class="pillar-head">
                <text class="pillar-label">{{item.label}}</text>
                <text class="pillar-divider">|</text>
                <text class="pillar-value">{{item.value}}</text>
              </view>
              <text class="pillar-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="section" wx:if="{{knowledgeNetwork.risks && knowledgeNetwork.risks.length}}">
        <text class="section-label">03 / 演进悖论与风险</text>
        <view class="risks-card">
          <view class="risk-item" wx:for="{{knowledgeNetwork.risks}}" wx:key="title">
            <view class="risk-dot"></view>
            <view class="risk-body">
              <text class="risk-title">{{item.title}}</text>
              <text class="risk-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="section">
        <view class="conclusion-card">
          <view class="conclusion-quote">"</view>
          <text class="conclusion-label">终极结论 / Conclusion</text>
          <text class="conclusion-text">{{ultimateConclusion}}</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="footer" wx:if="{{!loading}}">
    <view class="actions">
      <view class="action-btn action-{{item.type}} action-span-{{item.span}}" data-id="{{item.id}}" bindtap="onActionTap" wx:for="{{actions}}" wx:key="id">
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>
</view>
