/* 圆桌讨论 · 交锋页 - 阅读态 UI */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 280rpx;
  overflow-x: hidden;
  width: 100%;
  max-width: 100vw;
  margin: 0 auto;
  box-sizing: border-box;
}

/* Header */
.header {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 20;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.topic-block {
  padding: 24rpx 32rpx;
  background: rgba(249, 250, 251, 0.5);
  border-bottom: 1rpx solid #f0f0f0;
}

.topic-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #9ca3af;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.topic-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #111;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.step-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #60a5fa;
  border: 2rpx solid #fff;
}

.step-dot-done {
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
  box-shadow: none;
}

.step-dot-inactive {
  background: #f3f4f6;
  color: #6b7280;
  box-shadow: none;
}

.step-text {
  color: #111;
}

.step-text-inactive {
  color: #9ca3af;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #e5e7eb;
  margin: 0 24rpx;
  margin-bottom: 36rpx;
}

/* Main */
.main {
  height: calc(100vh - 320rpx);
  padding: 32rpx;
  overflow-x: hidden;
  max-width: 100%;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
  padding: 48rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: chat-spin 0.8s linear infinite;
}

@keyframes chat-spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.loading-meta {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.progress-wrap {
  margin-top: 32rpx;
  width: 100%;
  max-width: 400rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.progress-track {
  flex: 1;
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #07c160;
  border-radius: 6rpx;
  transition: width 0.2s ease;
}

.progress-label {
  font-size: 24rpx;
  color: #6b7280;
  min-width: 56rpx;
}

.round-badge {
  display: block;
  text-align: center;
  margin-bottom: 48rpx;
  background: #111;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  width: fit-content;
  margin-left: auto;
  margin-right: auto;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.section {
  margin-bottom: 48rpx;
}

.section-head {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.avatar-moderator {
  background: #2563eb;
}

.avatar-synthesis {
  background: #111;
}

.moderator-ask-card {
  background: rgba(239, 246, 255, 0.6);
  border: 1rpx solid #bfdbfe;
  border-radius: 24rpx;
  padding: 32rpx;
}

.moderator-ask-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1e3a8a;
}

.section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #6b7280;
}

.section-synthesis .section-title {
  color: #111;
  font-size: 26rpx;
}

/* Speeches */
.speeches {
  margin-bottom: 64rpx;
  padding-left: 16rpx;
  border-left: 1rpx solid #f3f4f6;
}

.speech-card {
  position: relative;
  margin-bottom: 48rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.speech-card:last-child {
  margin-bottom: 0;
}

.speech-accent {
  position: absolute;
  left: -16rpx;
  top: 48rpx;
  width: 4rpx;
  height: 56rpx;
  border-radius: 2rpx;
}

.speech-purple .speech-accent { background: #e9d5ff; }
.speech-green .speech-accent { background: #bbf7d0; }
.speech-blue .speech-accent { background: #bfdbfe; }

.speech-head {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f9fafb;
}

.speech-speaker {
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
}

.speech-action {
  font-size: 24rpx;
  color: #6b7280;
  font-style: italic;
  margin-top: 8rpx;
}

.speech-content {
  display: block;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.speech-tldr {
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid;
  position: relative;
}

.speech-tldr .tldr-label {
  position: absolute;
  top: -20rpx;
  left: 24rpx;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  border: 1rpx solid;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
}

.speech-tldr .tldr-text {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.6;
  margin-top: 12rpx;
}

.speech-tldr-purple {
  background: #f5f3ff;
  border-color: #e9d5ff;
}
.speech-tldr-purple .tldr-label { background: #e9d5ff; color: #6d28d9; border-color: #e9d5ff; }
.speech-tldr-purple .tldr-text { color: #6d28d9; }

.speech-tldr-green {
  background: #f0fdf4;
  border-color: #bbf7d0;
}
.speech-tldr-green .tldr-label { background: #bbf7d0; color: #15803d; border-color: #bbf7d0; }
.speech-tldr-green .tldr-text { color: #15803d; }

.speech-tldr-blue {
  background: #eff6ff;
  border-color: #bfdbfe;
}
.speech-tldr-blue .tldr-label { background: #bfdbfe; color: #1d4ed8; border-color: #bfdbfe; }
.speech-tldr-blue .tldr-text { color: #1d4ed8; }

/* Synthesis */
.synthesis-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.synthesis-block {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.synthesis-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #9ca3af;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.synthesis-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2937;
  line-height: 1.6;
}

.framework-block {
  background: #111;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  position: relative;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  max-width: 100%;
  overflow-x: auto;
  overflow-y: hidden;
}

.framework-hint {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 16rpx;
  text-align: center;
}

.framework-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #374151;
}

.framework-title {
  font-size: 20rpx;
  color: #9ca3af;
  font-family: monospace;
  letter-spacing: 0.05em;
}

.framework-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-red { background: #ef4444; }
.dot-yellow { background: #eab308; }
.dot-green { background: #22c55e; }

.framework-pre {
  display: block;
  font-size: 18rpx;
  font-family: monospace;
  color: #4ade80;
  line-height: 1.5;
  white-space: pre;
}

.deep-question-block {
  background: #fef2f2;
  border-left: 4rpx solid #ef4444;
  padding: 24rpx;
  border-radius: 0 12rpx 12rpx 0;
}

.deep-question-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #ef4444;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.deep-question-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #991b1b;
  line-height: 1.6;
}

/* Footer */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e5e7eb;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 30;
}

.footer-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #9ca3af;
  letter-spacing: 0.05em;
  text-align: center;
  margin-bottom: 16rpx;
}

.actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 30rpx;
  line-height: 1.3;
  flex: 1;
}

.action-main {
  display: block;
}

.action-sub {
  display: block;
  font-size: 20rpx;
  font-weight: 400;
  opacity: 0.8;
  margin-top: 4rpx;
}

.action-secondary {
  background: #fff;
  border: 1rpx solid #e5e7eb;
  color: #374151;
}

.action-primary {
  background: #111;
  color: #fff;
  border: 1rpx solid #111;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  transform: scale(1.02);
}

.action-danger {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  color: #dc2626;
}

/* 框架图横屏/全屏展示层 */
.framework-fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.framework-fullscreen-inner {
  width: 100%;
  max-width: 100%;
  max-height: 100%;
  display: flex;
  flex-direction: column;
  background: #111;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #333;
}

.framework-fullscreen-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #333;
  flex-shrink: 0;
}

.framework-fullscreen-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.framework-fullscreen-close {
  font-size: 28rpx;
  color: #60a5fa;
  padding: 12rpx 24rpx;
}

.framework-fullscreen-scroll {
  flex: 1;
  width: 100%;
  height: 60vh;
  min-height: 400rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.framework-fullscreen-pre {
  display: block;
  font-size: 24rpx;
  font-family: monospace;
  color: #4ade80;
  line-height: 1.6;
  white-space: pre;
  min-width: min-content;
  padding: 16rpx 0;
}

.framework-fullscreen-tip {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  text-align: center;
  padding: 20rpx;
  flex-shrink: 0;
}
