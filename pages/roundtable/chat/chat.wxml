<view class="page">
  <view class="header">
    <view class="topic-block">
      <text class="topic-label">当前议题 / TOPIC</text>
      <text class="topic-title">{{topic}}</text>
    </view>
    <view class="steps">
      <view class="step">
        <view class="step-dot step-dot-done"><text>✓</text></view>
        <text class="step-text step-text-inactive">邀请嘉宾</text>
      </view>
      <view class="step-line"></view>
      <view class="step step-active">
        <view class="step-dot"><text>2</text><view class="step-badge"></view></view>
        <text class="step-text">圆桌讨论</text>
      </view>
      <view class="step-line"></view>
      <view class="step">
        <view class="step-dot step-dot-inactive"><text>3</text></view>
        <text class="step-text step-text-inactive">话题总结</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="main">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingMessage}}</text>
      <text class="loading-meta">已接收 {{streamedLength}} 字</text>
      <view class="progress-wrap">
        <view class="progress-track">
          <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
        </view>
        <text class="progress-label">{{progressPercent}}%</text>
      </view>
    </view>
    <block wx:if="{{!loading}}">
      <block wx:for="{{rounds}}" wx:key="roundNum">
        <view class="round-badge">{{item.roundTitle}}</view>

        <view class="section section-moderator">
          <view class="section-head">
            <view class="avatar avatar-moderator">M</view>
            <text class="section-title">主持引导</text>
          </view>
          <view class="moderator-ask-card">
            <text class="moderator-ask-text">{{item.moderatorAsk}}</text>
          </view>
        </view>

        <view class="speeches">
          <view class="speech-card speech-{{speech.theme}}" wx:for="{{item.speeches}}" wx:for-item="speech" wx:key="index">
            <view class="speech-accent"></view>
            <view class="speech-head">
              <text class="speech-speaker">{{speech.speaker}}</text>
              <text class="speech-action">「{{speech.action}}」</text>
            </view>
            <text class="speech-content">{{speech.content}}</text>
            <view class="speech-tldr speech-tldr-{{speech.theme}}">
              <text class="tldr-label">简言之</text>
              <text class="tldr-text">{{speech.tldr}}</text>
            </view>
          </view>
        </view>

        <view class="section section-synthesis">
          <view class="section-head">
            <view class="avatar avatar-synthesis">M</view>
            <text class="section-title">本轮综述与框架提取</text>
          </view>
          <view class="synthesis-card">
            <view class="synthesis-block">
              <text class="synthesis-label">核心分歧点</text>
              <text class="synthesis-text">{{item.synthesis.coreConflict}}</text>
            </view>
            <view class="framework-block" wx:if="{{item.synthesis.framework}}" bindtap="onFrameworkTap">
              <view class="framework-header">
                <text class="framework-title">System.Graph()</text>
                <view class="framework-dots">
                  <view class="dot dot-red"></view>
                  <view class="dot dot-yellow"></view>
                  <view class="dot dot-green"></view>
                </view>
              </view>
              <text class="framework-pre">{{item.synthesis.framework}}</text>
              <text class="framework-hint">点击横屏展示</text>
            </view>
            <view class="deep-question-block">
              <text class="deep-question-label">深度拷问</text>
              <text class="deep-question-text">{{item.synthesis.deepQuestion}}</text>
            </view>
          </view>
        </view>
      </block>
    </block>
  </scroll-view>

  <view class="framework-fullscreen" wx:if="{{showFrameworkFullscreen}}" catchtap="onCloseFramework">
    <view class="framework-fullscreen-inner" catchtap="onFrameworkInnerTap">
      <view class="framework-fullscreen-head">
        <text class="framework-fullscreen-title">教育演进路径思考框架</text>
        <view class="framework-fullscreen-close" bindtap="onCloseFramework">关闭</view>
      </view>
      <scroll-view scroll-x scroll-y class="framework-fullscreen-scroll">
        <text class="framework-fullscreen-pre">{{synthesis.framework}}</text>
      </scroll-view>
      <text class="framework-fullscreen-tip">可横屏查看完整图示</text>
    </view>
  </view>

  <view class="footer" wx:if="{{!loading}}">
    <text class="footer-label">选择推演走向 / ACTION</text>
    <view class="actions">
      <view class="action-btn action-{{item.type}}" data-id="{{item.id}}" bindtap="onActionTap" wx:for="{{actions}}" wx:key="id">
        <text class="action-main">{{item.label}}</text>
        <text class="action-sub">{{item.sublabel}}</text>
      </view>
    </view>
  </view>
</view>
