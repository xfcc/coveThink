/* 圆桌讨论 · 邀请嘉宾 - 阅读态 UI */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
  overflow-x: hidden;
  width: 100%;
  max-width: 100vw;
}

/* Header */
.header {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 20;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.topic-block {
  padding: 24rpx 32rpx;
  background: rgba(249, 250, 251, 0.5);
  border-bottom: 1rpx solid #f0f0f0;
}

.topic-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #9ca3af;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.topic-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #111;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.step-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4ade80;
  border: 2rpx solid #fff;
}

.step-dot-inactive {
  background: #f3f4f6;
  color: #6b7280;
  box-shadow: none;
}

.step-text {
  color: #111;
}

.step-text-inactive {
  color: #9ca3af;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #e5e7eb;
  margin: 0 24rpx;
  margin-bottom: 36rpx;
}

/* Main */
.main {
  height: calc(100vh - 320rpx);
  padding: 32rpx;
  overflow-x: hidden;
  max-width: 100%;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
  padding: 48rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.section {
  margin-bottom: 48rpx;
}

.section-head {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #111;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #111;
}

.moderator-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.moderator-bar {
  position: absolute;
  left: 0;
  top: 0;
  width: 4rpx;
  height: 100%;
  background: #3b82f6;
}

.moderator-body {
  padding-left: 8rpx;
}

.moderator-p {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: #374151;
  margin-bottom: 24rpx;
}

.moderator-p:last-child {
  margin-bottom: 0;
}

/* Roster */
.roster-head {
  margin-bottom: 32rpx;
}

.roster-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
  margin-right: 16rpx;
}

.roster-tag {
  font-size: 20rpx;
  font-weight: 500;
  color: #9ca3af;
  border: 1rpx solid #e5e7eb;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  text-transform: uppercase;
}

.guests {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.guest-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.guest-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.guest-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  line-height: 1.3;
}

.guest-role {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
  margin-top: 8rpx;
}

.mbti {
  font-size: 20rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  border: 1rpx solid;
}

.mbti-purple {
  background: #f5f3ff;
  color: #6d28d9;
  border-color: #e9d5ff;
}

.mbti-green {
  background: #f0fdf4;
  color: #15803d;
  border-color: #bbf7d0;
}

.mbti-blue {
  background: #eff6ff;
  color: #1d4ed8;
  border-color: #bfdbfe;
}

.guest-stance {
  padding-top: 24rpx;
  border-top: 1rpx solid #f9fafb;
}

.stance-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #9ca3af;
  letter-spacing: 0.05em;
  margin-bottom: 12rpx;
}

.stance-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

/* Footer */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  border-top: 1rpx solid #f0f0f0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 30;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  background: #111;
  border: none;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.btn-primary::after {
  border: none;
}
