/* 现代极简大厅 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 48rpx 40rpx;
}

.header {
  margin-bottom: 56rpx;
}
.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #666;
}

.tool-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}
