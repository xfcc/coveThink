.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 48rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.icon-wrap {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: #fff;
  border: 1rpx solid #e5e5e5;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 48rpx;
  text-align: left;
}

.topic-box {
  width: 100%;
  margin-bottom: 48rpx;
  text-align: left;
}

.topic-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.topic-value {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  line-height: 1.5;
  box-sizing: border-box;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  background: #07c160;
  border: none;
  border-radius: 12rpx;
}

.btn::after {
  border: none;
}
